{
  "name": "omnis-apien",
  "version": "1.0.0",
  "description": "Browser-native civilization simulator with real capability orchestration, explicit fallbacks, and static-host deployment readiness.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean:dist": "node -e \"const fs=require('fs');for(const t of ['dist','dev-dist','release-dist']){if(fs.existsSync(t))fs.rmSync(t,{recursive:true,force:true});}\"",
    "clean": "node -e \"const fs=require('fs');const targets=['dist','dev-dist','release-dist','tsconfig.tsbuildinfo','wasm/target','wasm/pkg','rustup-init.exe','wasm-pack-init.exe','vs_buildtools.exe'];for(const t of targets){if(fs.existsSync(t))fs.rmSync(t,{recursive:true,force:true});}\"",
    "build": "node scripts/run-release-build.mjs",
    "build:clean": "npm run clean && npm run build",
    "serve:dist": "vite preview --host 0.0.0.0 --port 4173",
    "verify:release": "npm run typecheck -- --pretty false && npm run test -- --run && npm run build",
    "audit:requirements:private": "node scripts/audit-private-requirements.mjs",
    "render:readme": "node scripts/render-readme.mjs",
    "deploy:vercel": "npm run verify:release && npx vercel deploy --prod --yes",
    "deploy:netlify": "npm run verify:release && npx netlify deploy --prod --dir=release-dist",
    "deploy:netlify:anon": "npm run verify:release && npx netlify deploy --prod --dir=release-dist --json --allow-anonymous",
    "deploy:now": "npm run deploy:netlify:anon",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "wasm:build": "cd wasm && wasm-pack build --target web --out-dir ../src/wasm --release",
    "wasm:build:debug": "cd wasm && wasm-pack build --target web --out-dir ../src/wasm --dev",
    "wasm:build:simd": "cd wasm && wasm-pack build --target web --out-dir ../src/wasm --release -- --features simd",
    "postinstall": "echo 'WASM plugins integrated via Vite'"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.82",
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "date-fns": "^4.1.0",
    "eventemitter3": "^5.0.1",
    "howler": "^2.2.4",
    "immer": "^10.1.1",
    "motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.11.0",
    "three": "^0.170.0",
    "tone": "^15.0.4",
    "uuid": "^10.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-react-swc": "^3.7.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "jsdom": "^26.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "digital-civilization",
    "webgpu",
    "neural-network",
    "simulation",
    "quantum-computing",
    "wasm",
    "typescript",
    "react",
    "cyberpunk",
    "open-source"
  ],
  "author": "OMNIS APIEN Team",
  "license": "MIT"
}
